[Unit]
Description=AetherTFTP Headless TFTP Server (v@PROJECT_VERSION@)
Documentation=https://github.com/beratatmaca/AetherTFTP
After=network-online.target
Wants=network-online.target

[Service]
Type=simple

User=nobody
Group=nogroup

# Allow binding to port 69 without full root privileges.
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE

ExecStart=@CMAKE_INSTALL_FULL_BINDIR@/aethertftp \
    --server \
    --port 69 \
    --dir /var/lib/tftpboot \
    --json-log

Restart=on-failure
RestartSec=5s

# ---- Sandboxing ----
# Reduce the attack surface exposed to an exploit.
NoNewPrivileges=yes
PrivateTmp=yes
PrivateDevices=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/var/lib/tftpboot
ReadOnlyPaths=/etc
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
RestrictNamespaces=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
SystemCallFilter=@system-service
SystemCallErrorNumber=EPERM

# ---- Logging ----
# Route structured JSON output to the journal when StandardError=journal.
StandardOutput=null
StandardError=journal
SyslogIdentifier=aethertftp

[Install]
WantedBy=multi-user.target
