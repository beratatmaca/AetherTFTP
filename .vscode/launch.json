{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run GUI",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/aethertftp",
      "args": ["--gui"],
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        { "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "preLaunchTask": "Build"
    },
    {
      "name": "Run server (CLI)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/aethertftp",
      "args": ["--server", "--port", "6969", "--dir", "${workspaceFolder}"],
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        { "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "preLaunchTask": "Build"
    },
    {
      "name": "Debug tests",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/tftp_test",
      "args": [],
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        { "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "preLaunchTask": "Build"
    }
  ]
}
